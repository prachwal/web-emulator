{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "outgoing": {
    "gh": {
      "format": "file",
      "reason": "JSON mode sometimes fails; file mode is more reliable for issue operations"
    }
  },

  "mcp": {
    "font-dump": {
      "type": "local",
      "command": ["python3", "tools/font-mcp-server.py"],
      "enabled": true
    },
    "checklist": {
      "type": "local",
      "command": ["python3", "tools/checklist-mcp-server.py"],
      "enabled": true
    }
  }
}
