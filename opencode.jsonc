{
  "$schema": "https://opencode.ai/config.json",

  "lsp": true,

  "mcp": {
    "font-dump": {
      "type": "local",
      "command": ["python3", "tools/font-mcp-server.py"],
      "enabled": true
    },
    "checklist": {
      "type": "local",
      "command": ["python3", "tools/checklist-mcp-server.py"],
      "enabled": true
    }
  }
}
